{
  "version": 2,
  "functions": {
    "api/API/webhook.js": {
      "memory": 128,
      "maxDuration": 10
    },
    "api/API/cron.js": {
      "memory": 128,
      "maxDuration": 30
    },
    "api/API/compress.js": {
      "memory": 256,
      "maxDuration": 15
    }
  },
  "crons": [
    {
      "path": "/api/API/cron",
      "schedule": "*/15 * * * *"
    }
  ]
}
