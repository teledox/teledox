{
  "version": 2,
  "outputDirectory": "public",
  "builds": [
    {
      "src": "api/api/*.js",
      "use": "@vercel/node"
    },
    {
      "src": "public/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    { "src": "/api/api/(.*)", "dest": "/api/api/$1" },
    { "src": "/", "dest": "/public/index.html" },
    { "src": "/(.*)", "dest": "/$1" }
  ]
}
