{
  "version": 2,
  "routes": [
    { "src": "/panel/(.*)", "dest": "/panel/$1" },
    { "src": "/panel", "dest": "/panel/index.html" }
  ],
  "functions": {
    "api-v2/api/webhook.js": {
      "memory": 128,
      "maxDuration": 10
    },
    "api-v2/api/cron.js": {
      "memory": 128,
      "maxDuration": 30
    },
    "api-v2/api/compress.js": {
      "memory": 256,
      "maxDuration": 15
    }
  },
  "crons": [
    {
      "path": "/api-v2/api/cron",
      "schedule": "*/15 * * * *"
    }
  ]
}
