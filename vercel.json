{
  "version": 2,
  "functions": {
    "API/api/webhook.js": {
      "memory": 128,
      "maxDuration": 10
    },
    "API/api/cron.js": {
      "memory": 128,
      "maxDuration": 30
    },
    "API/api/compress.js": {
      "memory": 256,
      "maxDuration": 15
    }
  },
  "routes": [
    {
      "src": "/api/webhook",
      "dest": "/API/api/webhook.js"
    },
    {
      "src": "/api/cron",
      "dest": "/API/api/cron.js"
    },
    {
      "src": "/(.*)",
      "dest": "/público/índice.html"
    }
  ],
  "crons": [
    {
      "path": "/api/cron",
      "schedule": "0 8 * * *"
    }
  ]
}
