{
  "version": 2,
  "functions": {
    "api/api/webhook.js": {
      "memory": 128,
      "maxDuration": 10
    },
    "api/api/cron.js": {
      "memory": 128,
      "maxDuration": 30
    },
    "api/api/compress.js": {
      "memory": 256,
      "maxDuration": 15
    }
  },
  "builds": [
    {
      "src": "api/api/*.js",
      "use": "@vercel/node"
    },
    {
      "src": "index.html",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    { "src": "/api/api/(.*)", "dest": "/api/api/$1" },
    { "src": "/(.*)", "dest": "/$1" }
  ]
}
