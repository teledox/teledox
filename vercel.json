{
  "version": 2,
  "outputDirectory": "public",
  "installCommand": "npm install",
  "functions": {
    "api/webhook.js":   { "maxDuration": 10, "includeFiles": "node_modules/pdf-lib/**,node_modules/@pdf-lib/**" },
    "api/enviar-docs.js": { "maxDuration": 15 },
    "api/cron.js":      { "maxDuration": 30 },
    "api/compress.js":  { "maxDuration": 15 }
  },
  "redirects": [
    { "source": "/", "destination": "/landing/", "permanent": true }
  ],
  "rewrites": [
    { "source": "/plataforma", "destination": "/index.html" }
  ]
}
